@model ExamNavigator.Mvc.Models.ExamNavigationPageViewModel

@{
    ViewData["Title"] = "Exam Navigator";
}

<div id="exam-navigation-root">
    @await Html.PartialAsync("_ExamNavigationPage", Model)
</div>

<script>
(function () {
    const root = document.getElementById('exam-navigation-root');
    if (!root) {
        return;
    }

    let activeRequestController = null;

    function abortActiveRequest() {
        if (activeRequestController) {
            activeRequestController.abort();
            activeRequestController = null;
        }
    }

    function isModifiedClick(event) {
        return event.defaultPrevented ||
            event.button !== 0 ||
            event.metaKey ||
            event.ctrlKey ||
            event.shiftKey ||
            event.altKey;
    }

    function beginRequest() {
        abortActiveRequest();
        activeRequestController = new AbortController();
        root.setAttribute('aria-busy', 'true');
        return activeRequestController;
    }

    function endRequest(controller) {
        if (activeRequestController === controller) {
            activeRequestController = null;
        }

        root.removeAttribute('aria-busy');
    }

    async function renderFragmentFromResponse(response) {
        if (!response.ok) {
            throw new Error('HTTP ' + response.status);
        }

        const html = await response.text();
        root.innerHTML = html;
    }

    async function fetchFragment(url, options) {
        const controller = beginRequest();

        try {
            const response = await fetch(url, {
                ...options,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    ...(options && options.headers ? options.headers : {})
                },
                signal: controller.signal
            });

            await renderFragmentFromResponse(response);
            return response;
        } finally {
            endRequest(controller);
        }
    }

    root.addEventListener('click', async function (event) {
        const link = event.target.closest('a[href]');
        if (!link) {
            return;
        }

        if (!root.contains(link)) {
            return;
        }

        if (isModifiedClick(event)) {
            return;
        }

        const href = link.getAttribute('href');
        if (!href || href.startsWith('#')) {
            return;
        }

        const url = new URL(href, window.location.origin);
        if (url.origin !== window.location.origin) {
            return;
        }

        event.preventDefault();

        try {
            await fetchFragment(url.toString(), {
                method: 'GET',
                credentials: 'same-origin'
            });

            window.history.pushState({}, '', url);
        } catch (error) {
            if (error && error.name === 'AbortError') {
                return;
            }

            window.location.assign(url.toString());
        }
    });

    root.addEventListener('submit', async function (event) {
        const form = event.target;
        if (!(form instanceof HTMLFormElement)) {
            return;
        }

        if (!root.contains(form)) {
            return;
        }

        event.preventDefault();

        const method = (form.getAttribute('method') || 'get').toUpperCase();
        const action = form.getAttribute('action') || window.location.href;
        const url = new URL(action, window.location.origin);
        const formData = new FormData(form, event.submitter || undefined);

        try {
            if (method === 'GET') {
                const params = new URLSearchParams();

                for (const [key, value] of formData.entries()) {
                    params.append(key, String(value));
                }

                url.search = params.toString();

                await fetchFragment(url.toString(), {
                    method: 'GET',
                    credentials: 'same-origin'
                });

                window.history.pushState({}, '', url);
                return;
            }

            await fetchFragment(url.toString(), {
                method: method,
                body: formData,
                credentials: 'same-origin'
            });
        } catch (error) {
            if (error && error.name === 'AbortError') {
                return;
            }

            form.submit();
        }
    });

    window.addEventListener('popstate', async function () {
        try {
            await fetchFragment(window.location.href, {
                method: 'GET',
                credentials: 'same-origin'
            });
        } catch {
            window.location.reload();
        }
    });
})();
</script>
