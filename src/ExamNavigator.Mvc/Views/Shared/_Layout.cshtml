<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Exam Navigator</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ExamNavigator.Mvc.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header border-bottom">
        <div class="container py-3 d-flex justify-content-between align-items-center">
            <a class="app-brand text-decoration-none" asp-area="" asp-controller="Home" asp-action="Index">
                Exam Navigator
            </a>
            <nav class="d-flex gap-3">
                <a class="app-nav-link" asp-area="" asp-controller="Home" asp-action="Index">Navigazione esami</a>
            </nav>
        </div>
    </header>

    <div class="container app-main">
        <main role="main" class="py-4">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer border-top">
        <div class="container py-3 text-muted small">
            Baseline MVC progressiva allineata al progetto Exam Navigator.
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
